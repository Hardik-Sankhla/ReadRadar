---
const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-[#0A0A0A]/90 backdrop-blur-md border-b-2 border-[#333333]">
    <div class="max-w-[90rem] mx-auto px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-4">
            <a href={`${import.meta.env.BASE_URL}/`.replace(/\/\/+/g, '/')} class="flex items-center gap-4 group">
                <div class="w-10 h-10 bg-[#7C3AED] border-2 border-white flex items-center justify-center font-heading font-bold text-white text-xl shadow-[4px_4px_0px_0px_#FFFFFF] group-hover:shadow-[2px_2px_0px_0px_#FFFFFF] transition-all duration-200">RR</div>
                <span class="font-heading font-bold text-xl text-white tracking-tight">Read<span class="text-[#7C3AED]">Radar</span></span>
            </a>
        </div>
        
        <div class="hidden lg:flex gap-4 font-mono text-[10px] text-gray-500 items-center border border-[#333333] px-3 py-1.5 bg-[#0A0A0A] shadow-[inset_2px_2px_0px_0px_#171717]">
            <span class="flex items-center gap-1"><span class="text-white font-bold">4,218</span> RES</span>
            <span class="w-[1px] h-3 bg-[#333333]"></span>
            <span class="flex items-center gap-1"><span class="text-white font-bold">87</span> COL</span>
            <span class="w-[1px] h-3 bg-[#333333]"></span>
            <span class="flex items-center gap-1"><span class="text-white font-bold">19</span> DOM</span>
            <span class="w-[1px] h-3 bg-[#333333]"></span>
            <span>SYNC: <span class="text-[#10B981]">8m ago</span></span>
            <span class="w-[1px] h-3 bg-[#333333]"></span>
            <span class="flex items-center gap-1">AGENT: <span class="w-1.5 h-1.5 rounded-full bg-[#10B981] animate-pulse"></span></span>
        </div>

        <div class="hidden md:flex gap-6 font-mono text-sm font-medium items-center">
            <a href={`${import.meta.env.BASE_URL}/discover`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group ${currentPath.includes('/discover') ? 'text-white' : 'text-gray-500 hover:text-white'}`}>
                Discover
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/discover') ? 'bg-[#7C3AED] shadow-[0_0_8px_#7C3AED]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            <a href={`${import.meta.env.BASE_URL}/domains`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group ${currentPath.includes('/domains') ? 'text-white' : 'text-gray-500 hover:text-white'}`}>
                Domains
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/domains') ? 'bg-[#7C3AED] shadow-[0_0_8px_#7C3AED]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            <a href={`${import.meta.env.BASE_URL}/trending`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group ${currentPath.includes('/trending') ? 'text-white' : 'text-gray-500 hover:text-white'}`}>
                Trending
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/trending') ? 'bg-[#7C3AED] shadow-[0_0_8px_#7C3AED]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            <a href={`${import.meta.env.BASE_URL}/collections`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group ${currentPath.includes('/collections') ? 'text-white' : 'text-gray-500 hover:text-white'}`}>
                Collections
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/collections') ? 'bg-[#7C3AED] shadow-[0_0_8px_#7C3AED]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            <a href={`${import.meta.env.BASE_URL}/about`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group ${currentPath.includes('/about') ? 'text-white' : 'text-gray-500 hover:text-white'}`}>
                About
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/about') ? 'bg-[#7C3AED] shadow-[0_0_8px_#7C3AED]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            
            <div class="h-6 w-[2px] bg-[#333333] mx-2"></div>
            
            <button onclick="window.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', ctrlKey: true }))" class="text-gray-500 hover:text-[#7C3AED] px-1 py-2 transition-colors duration-200 group flex items-center gap-2" title="Search (Ctrl+K)">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2 group-hover:scale-110 transition-transform"><path stroke-linecap="square" stroke-linejoin="miter" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </button>
            <a href="https://github.com/Hardik-Sankhla/ReadRadar" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white px-1 py-2 transition-colors duration-200 group flex items-center gap-2" title="GitHub">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current group-hover:scale-110 transition-transform"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <a href="https://t.me" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-[#06B6D4] px-1 py-2 transition-colors duration-200 group flex items-center gap-2" title="Telegram">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current group-hover:scale-110 transition-transform"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.33-.01-.98-.19-1.46-.35-.59-.19-1.05-.29-1-.61.03-.17.26-.34.69-.53 2.76-1.2 4.61-1.98 5.56-2.37 2.65-1.1 3.2-1.29 3.56-1.29.08 0 .25.02.36.1.1.07.16.17.18.29.01.07.02.16.02.24z"/></svg>
            </a>
            <button class="text-gray-500 hover:text-[#F59E0B] px-1 py-2 transition-colors duration-200 group flex items-center gap-2" title="Toggle Theme (Coming Soon)">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2 group-hover:scale-110 transition-transform"><circle cx="12" cy="12" r="5"></circle><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path></svg>
            </button>
        </div>
    </div>
</nav>
