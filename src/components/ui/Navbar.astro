---
const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-[#0A0A0A]/90 backdrop-blur-md border-b-2 border-[#333333]">
    <div class="max-w-[90rem] mx-auto px-4 sm:px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-3 md:gap-4 shrink-0">
            <a href={`${import.meta.env.BASE_URL}/`.replace(/\/\/+/g, '/')} class="flex items-center gap-2 md:gap-3 group focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] focus-visible:ring-offset-2 focus-visible:ring-offset-[#0A0A0A] rounded-md shrink-0">
                <div class="w-8 h-8 md:w-10 md:h-10 bg-[#7C3AED] border-2 border-white flex items-center justify-center font-heading font-bold text-white text-base md:text-xl shadow-[4px_4px_0px_0px_#FFFFFF] group-hover:shadow-[2px_2px_0px_0px_#FFFFFF] transition-all duration-200 shrink-0">RR</div>
                <span class="font-heading font-bold text-lg md:text-xl text-white tracking-tight whitespace-nowrap">Read<span class="text-[#7C3AED]">Radar</span></span>
            </a>
        </div>
        
        <div class="flex items-center gap-3 md:gap-4 shrink-0">
            <div class="hidden xl:flex gap-3 font-mono text-[10px] text-gray-400 items-center border border-[#333333] px-2 py-1 bg-[#0A0A0A] shadow-[inset_2px_2px_0px_0px_#171717]">
                <span class="flex items-center gap-1"><span class="text-white font-bold">73</span> RES</span>
                <span class="w-[1px] h-3 bg-[#333333]"></span>
                <span class="flex items-center gap-1"><span class="text-white font-bold">5</span> COL</span>
                <span class="w-[1px] h-3 bg-[#333333]"></span>
                <span class="flex items-center gap-1"><span class="text-white font-bold">8</span> DOM</span>
                <span class="w-[1px] h-3 bg-[#333333]"></span>
                <span>AGENT: <span class="w-1.5 h-1.5 rounded-full bg-[#10B981] animate-pulse inline-block"></span></span>
            </div>
    
            <!-- Desktop Navigation -->
            <div class="hidden md:flex gap-2 lg:gap-3 font-mono text-sm font-medium items-center">
            <a href={`${import.meta.env.BASE_URL}/discover`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] rounded-sm ${currentPath.includes('/discover') ? 'text-white' : 'text-gray-400 hover:text-white'}`}>
                Discover
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/discover') ? 'bg-[#7C3AED] shadow-[0_0_8px_#7C3AED]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            <a href={`${import.meta.env.BASE_URL}/domains`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] rounded-sm ${currentPath.includes('/domains') ? 'text-white' : 'text-gray-400 hover:text-white'}`}>
                Domains
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/domains') ? 'bg-[#7C3AED] shadow-[0_0_8px_#7C3AED]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            <a href={`${import.meta.env.BASE_URL}/trending`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] rounded-sm ${currentPath.includes('/trending') ? 'text-white' : 'text-gray-400 hover:text-white'}`}>
                Trending
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/trending') ? 'bg-[#7C3AED] shadow-[0_0_8px_#7C3AED]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            <a href={`${import.meta.env.BASE_URL}/collections`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] rounded-sm ${currentPath.includes('/collections') ? 'text-white' : 'text-gray-400 hover:text-white'}`}>
                Collections
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/collections') ? 'bg-[#7C3AED] shadow-[0_0_8px_#7C3AED]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            <a href={`${import.meta.env.BASE_URL}/journeys`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] rounded-sm ${currentPath.includes('/journeys') ? 'text-white' : 'text-gray-400 hover:text-white'}`}>
                Journeys
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/journeys') ? 'bg-[#7C3AED] shadow-[0_0_8px_#7C3AED]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            <a href={`${import.meta.env.BASE_URL}/careers`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group focus:outline-none focus-visible:ring-2 focus-visible:ring-[#10B981] rounded-sm ${currentPath.includes('/careers') ? 'text-white' : 'text-gray-400 hover:text-white'}`}>
                Careers
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/careers') ? 'bg-[#10B981] shadow-[0_0_8px_#10B981]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            <a href={`${import.meta.env.BASE_URL}/status/intelligence`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group focus:outline-none focus-visible:ring-2 focus-visible:ring-[#06B6D4] rounded-sm ${currentPath.includes('/status/intelligence') ? 'text-white' : 'text-gray-400 hover:text-white'}`}>
                Intelligence
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/status/intelligence') ? 'bg-[#06B6D4] shadow-[0_0_8px_#06B6D4]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            <a href={`${import.meta.env.BASE_URL}/about`.replace(/\/\/+/g, '/')} class={`px-1 py-2 transition-all duration-300 relative group focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] rounded-sm ${currentPath.includes('/about') ? 'text-white' : 'text-gray-400 hover:text-white'}`}>
                About
                <span class={`absolute bottom-0 left-0 w-full h-[2px] transition-all duration-300 ${currentPath.includes('/about') ? 'bg-[#7C3AED] shadow-[0_0_8px_#7C3AED]' : 'bg-transparent group-hover:bg-gray-600'}`}></span>
            </a>
            
            <div class="h-6 w-[2px] bg-[#333333] mx-2"></div>
            
            <button onclick="window.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', ctrlKey: true }))" class="text-gray-400 hover:text-[#7C3AED] px-1 py-2 transition-colors duration-200 group flex items-center gap-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] rounded-sm" title="Search (Ctrl+K)">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2 group-hover:scale-110 transition-transform"><path stroke-linecap="square" stroke-linejoin="miter" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </button>
            <a href="https://github.com/Hardik-Sankhla/ReadRadar" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white px-1 py-2 transition-colors duration-200 group flex items-center gap-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] rounded-sm" title="GitHub">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current group-hover:scale-110 transition-transform"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <a href="https://github.com/Hardik-Sankhla/ReadRadar/issues" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-[#06B6D4] px-1 py-2 transition-colors duration-200 group flex items-center gap-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#06B6D4] rounded-sm" title="Report Issue">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2 group-hover:scale-110 transition-transform"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            </a>
            <button class="text-gray-400 hover:text-[#F59E0B] px-1 py-2 transition-colors duration-200 group flex items-center gap-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F59E0B] rounded-sm" title="Toggle Theme (Coming Soon)">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2 group-hover:scale-110 transition-transform"><circle cx="12" cy="12" r="5"></circle><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path></svg>
            </button>
        </div>

        <!-- Mobile Menu Toggle -->
        <button id="mobile-menu-btn" class="md:hidden text-gray-400 hover:text-white p-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] rounded-md transition-colors" aria-label="Toggle Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
        </div>
    </div>

    <!-- Mobile Navigation Dropdown -->
    <div id="mobile-menu" class="hidden md:hidden absolute top-20 left-0 w-full bg-[#0A0A0A]/95 backdrop-blur-xl border-b-2 border-[#333333] shadow-2xl flex-col divide-y divide-[#222]">
        <div class="px-6 py-4 flex flex-col gap-4 font-mono text-sm font-medium">
            <a href={`${import.meta.env.BASE_URL}/discover`.replace(/\/\/+/g, '/')} class={`block p-2 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] ${currentPath.includes('/discover') ? 'text-white bg-[#171717]' : 'text-gray-400 hover:text-white'}`}>Discover</a>
            <a href={`${import.meta.env.BASE_URL}/domains`.replace(/\/\/+/g, '/')} class={`block p-2 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] ${currentPath.includes('/domains') ? 'text-white bg-[#171717]' : 'text-gray-400 hover:text-white'}`}>Domains</a>
            <a href={`${import.meta.env.BASE_URL}/trending`.replace(/\/\/+/g, '/')} class={`block p-2 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] ${currentPath.includes('/trending') ? 'text-white bg-[#171717]' : 'text-gray-400 hover:text-white'}`}>Trending</a>
            <a href={`${import.meta.env.BASE_URL}/collections`.replace(/\/\/+/g, '/')} class={`block p-2 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] ${currentPath.includes('/collections') ? 'text-white bg-[#171717]' : 'text-gray-400 hover:text-white'}`}>Collections</a>
            <a href={`${import.meta.env.BASE_URL}/journeys`.replace(/\/\/+/g, '/')} class={`block p-2 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] ${currentPath.includes('/journeys') ? 'text-white bg-[#171717]' : 'text-gray-400 hover:text-white'}`}>Journeys</a>
            <a href={`${import.meta.env.BASE_URL}/careers`.replace(/\/\/+/g, '/')} class={`block p-2 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[#10B981] ${currentPath.includes('/careers') ? 'text-[#10B981] bg-[#171717]' : 'text-gray-400 hover:text-[#10B981]'}`}>Careers</a>
            <a href={`${import.meta.env.BASE_URL}/status/intelligence`.replace(/\/\/+/g, '/')} class={`block p-2 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[#06B6D4] ${currentPath.includes('/status/intelligence') ? 'text-[#06B6D4] bg-[#171717]' : 'text-gray-400 hover:text-[#06B6D4]'}`}>Intelligence</a>
            <a href={`${import.meta.env.BASE_URL}/about`.replace(/\/\/+/g, '/')} class={`block p-2 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED] ${currentPath.includes('/about') ? 'text-white bg-[#171717]' : 'text-gray-400 hover:text-white'}`}>About</a>
        </div>
        <div class="px-6 py-4 flex items-center gap-6">
            <button onclick="window.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', ctrlKey: true }))" class="text-gray-400 hover:text-[#7C3AED] flex items-center gap-2 p-2 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED]">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2"><path stroke-linecap="square" stroke-linejoin="miter" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <span class="font-mono text-sm">Search</span>
            </button>
            <a href="https://github.com/Hardik-Sankhla/ReadRadar" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white p-2 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7C3AED]">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
        </div>
    </div>
</nav>

<script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
        btn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
            menu.classList.toggle('flex');
        });
    }
</script>
