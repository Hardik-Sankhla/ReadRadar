---
const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-[#0A0A0A]/90 backdrop-blur-md border-b-2 border-[#333333]">
    <div class="max-w-[90rem] mx-auto px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-4">
            <a href="/" class="flex items-center gap-4 group">
                <div class="w-10 h-10 bg-[#F59E0B] border-2 border-white flex items-center justify-center font-heading font-bold text-black text-xl shadow-[4px_4px_0px_0px_#FFFFFF] group-hover:shadow-[2px_2px_0px_0px_#FFFFFF] transition-all">RR</div>
                <span class="font-heading font-bold text-xl text-white tracking-tight">Read<span class="text-[#F59E0B]">Radar</span></span>
            </a>
        </div>
        <div class="hidden md:flex gap-6 font-mono text-sm font-medium items-center">
            <a href="/discover" class={`px-1 py-2 transition-colors ${currentPath.includes('/discover') ? 'text-white border-b-2 border-[#F59E0B]' : 'text-gray-500 hover:text-white'}`}>Discover</a>
            <a href="/domains" class={`px-1 py-2 transition-colors ${currentPath.includes('/domains') ? 'text-white border-b-2 border-[#F59E0B]' : 'text-gray-500 hover:text-white'}`}>Domains</a>
            <a href="/trending" class={`px-1 py-2 transition-colors ${currentPath.includes('/trending') ? 'text-white border-b-2 border-[#F59E0B]' : 'text-gray-500 hover:text-white'}`}>Trending</a>
            <a href="/collections" class={`px-1 py-2 transition-colors ${currentPath.includes('/collections') ? 'text-white border-b-2 border-[#F59E0B]' : 'text-gray-500 hover:text-white'}`}>Collections</a>
            <a href="/about" class={`px-1 py-2 transition-colors ${currentPath.includes('/about') ? 'text-white border-b-2 border-[#F59E0B]' : 'text-gray-500 hover:text-white'}`}>About</a>
            <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white px-1 py-2 transition-colors group flex items-center gap-2">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current group-hover:scale-110 transition-transform"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
        </div>
    </div>
</nav>
