---
---

<footer class="border-t-2 border-[#333333] bg-[#171717] mt-24">
    <div class="max-w-[90rem] mx-auto px-6 py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
            <div class="col-span-1 md:col-span-1">
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-8 h-8 bg-[#7C3AED] border-2 border-white flex items-center justify-center font-heading font-bold text-white text-sm shadow-[2px_2px_0px_0px_#FFFFFF]">RR</div>
                    <span class="font-heading font-bold text-lg text-white tracking-tight">Read<span class="text-[#7C3AED]">Radar</span></span>
                </div>
                <p class="text-sm text-gray-400 font-mono">
                    The Intelligence Layer<br />
                    for Technical Knowledge
                </p>
                <div class="mt-6 flex flex-col gap-2 font-mono text-xs text-gray-500">
                    <span>© 2026 ReadRadar</span>
                    <span>Powered by BookOS</span>
                    <span class="flex items-center gap-2 mt-2">
                        <span class="px-1.5 py-0.5 bg-[#333333] text-white border border-[#444] rounded-sm">Open Source</span>
                    </span>
                </div>
            </div>
            
            <div>
                <h4 class="font-heading font-bold text-white uppercase mb-4 text-sm tracking-wider">Resources</h4>
                <ul class="space-y-3 font-mono text-sm">
                    <li><a href={`${import.meta.env.BASE_URL}discover`} class="text-gray-500 hover:text-[#7C3AED] transition-colors">Discover</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}trending`} class="text-gray-500 hover:text-[#7C3AED] transition-colors">Trending</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}collections`} class="text-gray-500 hover:text-[#7C3AED] transition-colors">Collections</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}domains`} class="text-gray-500 hover:text-[#7C3AED] transition-colors">Domains</a></li>
                </ul>
            </div>
            
            <div>
                <h4 class="font-heading font-bold text-white uppercase mb-4 text-sm tracking-wider">Community</h4>
                <ul class="space-y-3 font-mono text-sm">
                    <li><a href="https://github.com/Hardik-Sankhla/ReadRadar" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors">GitHub</a></li>
                    <li><a href="https://t.me" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors">Telegram</a></li>
                    <li><span class="text-gray-600">Discord (Coming Soon)</span></li>
                    <li><a href="#" class="text-gray-500 hover:text-white transition-colors">RSS Feed</a></li>
                </ul>
            </div>
            
            <div>
                <h4 class="font-heading font-bold text-white uppercase mb-4 text-sm tracking-wider">Open Source</h4>
                <ul class="space-y-3 font-mono text-sm">
                    <li><span class="text-gray-500 hover:text-white transition-colors cursor-pointer">MIT License</span></li>
                    <li><span class="text-gray-500">Version: <span class="text-white">v1.1</span></span></li>
                    <li><span class="text-gray-500">Build: <span class="text-white">b7a89f2</span></span></li>
                    <li><span class="text-gray-500">Updated: <span class="text-white">Today</span></span></li>
                    <li class="pt-4"><span class="text-gray-400">Made with ❤️</span></li>
                </ul>
            </div>
        </div>
    </div>
</footer>
