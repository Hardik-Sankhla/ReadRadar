---
---

<footer class="border-t-2 border-[#333333] bg-[#171717] mt-24">
    <div class="max-w-[90rem] mx-auto px-4 sm:px-6 py-10 md:py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12">
            <!-- Brand -->
            <div class="col-span-1 md:col-span-1">
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-8 h-8 bg-[#7C3AED] border-2 border-white flex items-center justify-center font-heading font-bold text-white text-sm shadow-[2px_2px_0px_0px_#FFFFFF]">RR</div>
                    <span class="font-heading font-bold text-lg text-white tracking-tight">Read<span class="text-[#7C3AED]">Radar</span></span>
                </div>
                <p class="text-sm text-gray-400 font-mono leading-relaxed">
                    The AI Learning Operating System.<br/>
                    Goal-first. Graph-powered.
                </p>
                <div class="mt-6 flex flex-col gap-2 font-mono text-xs text-gray-500">
                    <span>© 2026 ReadRadar</span>
                    <span>Powered by BookOS</span>
                    <span class="flex items-center gap-2 mt-2">
                        <span class="px-1.5 py-0.5 bg-[#333333] text-white border border-[#444] rounded-sm">MIT License</span>
                        <span class="px-1.5 py-0.5 bg-[#7C3AED]/20 text-[#A78BFA] border border-[#7C3AED]/40 rounded-sm">Open Source</span>
                    </span>
                </div>
            </div>

            <!-- Navigate -->
            <div>
                <h4 class="font-heading font-bold text-white uppercase mb-4 text-sm tracking-wider">Navigate</h4>
                <ul class="space-y-3 font-mono text-sm">
                    <li><a href={`${import.meta.env.BASE_URL}/`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-[#7C3AED] transition-colors">Home</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}/discover`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-[#7C3AED] transition-colors">Discover</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}/trending`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-[#7C3AED] transition-colors">Trending</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}/collections`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-[#7C3AED] transition-colors">Collections</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}/journeys`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-[#7C3AED] transition-colors">Journeys</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}/domains`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-[#7C3AED] transition-colors">Domains</a></li>
                </ul>
            </div>

            <!-- Platform -->
            <div>
                <h4 class="font-heading font-bold text-white uppercase mb-4 text-sm tracking-wider">Platform</h4>
                <ul class="space-y-3 font-mono text-sm">
                    <li><a href={`${import.meta.env.BASE_URL}/journeys`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-white transition-colors">Learning Journeys</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}/status/intelligence`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-white transition-colors">Intelligence Dashboard</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}/status/runtime`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-white transition-colors">Runtime Status</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}/status`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-white transition-colors">Platform Status</a></li>
                    <li><a href={`${import.meta.env.BASE_URL}/about`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-white transition-colors">About</a></li>
                </ul>
            </div>

            <!-- GitHub -->
            <div>
                <h4 class="font-heading font-bold text-white uppercase mb-4 text-sm tracking-wider">Open Source</h4>
                <ul class="space-y-3 font-mono text-sm">
                    <li>
                        <a href="https://github.com/Hardik-Sankhla/ReadRadar" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors flex items-center gap-2">
                            <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                            ReadRadar
                        </a>
                    </li>
                    <li>
                        <a href="https://github.com/Hardik-Sankhla/BookOS" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors flex items-center gap-2">
                            <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                            BookOS
                        </a>
                    </li>
                    <li>
                        <a href="https://github.com/Hardik-Sankhla/KnowledgeRegistry" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors flex items-center gap-2">
                            <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                            KnowledgeRegistry
                        </a>
                    </li>
                    <li>
                        <a href="https://github.com/Hardik-Sankhla/ReadRadar/issues" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-[#E11D48] transition-colors">
                            Report an Issue
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom bar -->
        <div class="mt-12 pt-8 border-t border-[#222] flex flex-col md:flex-row justify-between items-center gap-4">
            <span class="font-mono text-xs text-gray-600">
                Made with ❤️ by <a href="https://github.com/Hardik-Sankhla" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors">Hardik Sankhla</a>
            </span>
            <div class="flex items-center gap-4 font-mono text-xs text-gray-600">
                <span>Deployed on GitHub Pages</span>
                <span class="w-[1px] h-3 bg-[#333]"></span>
                <span>Built with Astro</span>
                <span class="w-[1px] h-3 bg-[#333]"></span>
                <a href={`${import.meta.env.BASE_URL}/status/runtime`.replace(/\/\/+/g, '/')} class="hover:text-[#10B981] transition-colors flex items-center gap-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#10B981] inline-block"></span>
                    All Systems Online
                </a>
            </div>
        </div>
    </div>
</footer>
