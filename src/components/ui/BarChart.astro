---
interface DataPoint {
  label: string;
  value: number;
}

interface Props {
  data: DataPoint[];
  color?: string;
  maxHeight?: string;
}

const { data, color = "bg-[#10B981]", maxHeight = "h-64" } = Astro.props;

// Calculate max value for scaling
const maxValue = Math.max(...data.map(d => d.value), 1);
---

<div class={`flex items-end gap-2 md:gap-4 w-full border-b-2 border-l-2 border-[#333333] p-4 ${maxHeight}`}>
  {data.map((point) => (
    <div class="flex flex-col items-center flex-1 h-full justify-end group">
      {/* Tooltip on hover (CSS only) */}
      <div class="opacity-0 group-hover:opacity-100 transition-opacity bg-white text-black font-mono text-xs px-2 py-1 mb-2 font-bold z-10 pointer-events-none shadow-[2px_2px_0px_0px_#7C3AED] border-2 border-[#333333]">
        {point.value}
      </div>
      
      {/* Bar */}
      <div 
        class={`${color} w-full max-w-[4rem] border-2 border-[#333333] transition-all duration-500 ease-out shadow-[2px_2px_0px_0px_#333333] group-hover:shadow-[0px_0px_0px_0px_#333333] group-hover:translate-y-[2px] group-hover:-translate-x-[2px]`}
        style={`height: ${(point.value / maxValue) * 100}%`}
      ></div>
      
      {/* Label */}
      <span class="text-gray-400 font-mono text-xs mt-4 truncate w-full text-center">
        {point.label}
      </span>
    </div>
  ))}
</div>
