---
interface Props {
  id: string;
  title: string;
  icon?: string;
  className?: string;
}

const { id, title, icon = "#", className = "" } = Astro.props;
---

<section id={id} class={`mb-24 ${className}`}>
    <header class="mb-10">
        <div class="flex items-center gap-4 mb-4">
            <span class="w-10 h-10 bg-white text-black flex items-center justify-center font-heading font-bold text-xl border-2 border-[#333333] shadow-[4px_4px_0px_0px_#F59E0B]">{icon}</span>
            <h2 class="font-heading text-3xl md:text-4xl font-bold text-white uppercase">{title}</h2>
        </div>
        <slot name="header" />
    </header>
    <slot />
</section>
