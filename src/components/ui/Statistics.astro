---
interface Props {
  value: string;
  label: string;
  color?: string;
}

const { value, label, color = "text-[#7C3AED]" } = Astro.props;
---

<div class="neo-card p-4 md:p-6 border-l-4 border-l-[#7C3AED] shadow-[4px_4px_0px_0px_#7C3AED] md:shadow-[6px_6px_0px_0px_#7C3AED] flex flex-col md:flex-row gap-2 md:gap-6 items-center">
    <div class="flex-shrink-0">
        <span class={`font-heading font-black text-3xl sm:text-4xl md:text-5xl ${color}`}>{value}</span>
    </div>
    <div class="text-center md:text-left">
        <h4 class="font-heading font-bold text-base md:text-xl text-white mb-1 md:mb-2 uppercase tracking-wide">{label}</h4>
        <slot />
    </div>
</div>
