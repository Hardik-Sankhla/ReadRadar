---
interface Props {
  value: string;
  label: string;
  color?: string;
}

const { value, label, color = "text-[#7C3AED]" } = Astro.props;
---

<div class="neo-card p-6 border-l-4 border-l-[#7C3AED] shadow-[6px_6px_0px_0px_#7C3AED] flex flex-col md:flex-row gap-6 items-center">
    <div class="flex-shrink-0">
        <span class={`font-heading font-black text-4xl md:text-5xl ${color}`}>{value}</span>
    </div>
    <div>
        <h4 class="font-heading font-bold text-xl text-white mb-2 uppercase tracking-wide">{label}</h4>
        <slot />
    </div>
</div>
