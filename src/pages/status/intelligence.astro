---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/ui/Section.astro';
import intelligenceReport from '../../data/intelligence_report.json';

const summary = intelligenceReport?.summary || {};
const evaluatedAt = intelligenceReport?.evaluated_at;
const overallPass = intelligenceReport?.overall_pass ?? false;

function fmt(val: any, suffix = '%'): string {
    if (val === null || val === undefined) return '—';
    if (typeof val === 'number') return `${val}${suffix}`;
    return String(val);
}

function statusBg(pass: boolean): string {
    return pass ? 'border-l-[var(--color-success)]' : 'border-l-[#EF4444]';
}
function statusColor(pass: boolean): string {
    return pass ? 'text-success' : 'text-[#EF4444]';
}
function statusLabel(pass: boolean): string {
    return pass ? '✓ PASS' : '✗ FAIL';
}
function pulseBg(pass: boolean): string {
    return pass ? 'bg-success' : 'bg-[#EF4444]';
}

// Graph metrics
const graphPass = summary.graph_pass ?? false;
const recsPass = summary.recommendations_pass ?? false;
const journeysPass = summary.journeys_pass ?? false;

const graphMetrics = [
    { label: 'Total Nodes', value: fmt(summary.total_nodes, ''), target: '—', pass: true, noThreshold: true },
    { label: 'Total Edges', value: fmt(summary.total_edges, ''), target: '—', pass: true, noThreshold: true },
    { label: 'Orphan Rate', value: fmt(summary.orphan_rate), target: '< 1%', pass: (summary.orphan_rate ?? 100) <= 1.0 },
    { label: 'Duplicate Rate', value: fmt(summary.duplicate_rate), target: '< 5%', pass: (summary.duplicate_rate ?? 100) <= 5.0 },
    { label: 'Collection Coverage', value: fmt(summary.collection_coverage), target: '> 80%', pass: (summary.collection_coverage ?? 0) >= 80.0 },
    { label: 'Recommendation Coverage', value: fmt(summary.recommendation_coverage), target: '> 70%', pass: (summary.recommendation_coverage ?? 0) >= 70.0 },
];

const recMetrics = [
    { label: 'Graph Utilization', value: fmt(summary.graph_utilization), target: '> 70%', pass: (summary.graph_utilization ?? 0) >= 70.0 },
];

const journeyMetrics = [
    { label: 'Journey Count', value: fmt(summary.journey_count, ''), target: '≥ 1', pass: (summary.journey_count ?? 0) >= 1 },
    { label: 'Phase Balance Score', value: fmt(summary.phase_balance_score, '/100'), target: '> 80', pass: (summary.phase_balance_score ?? 0) >= 80.0 },
];
---

<Layout title="Intelligence Dashboard | ReadRadar">
    <header class="mb-16 pb-8">
        <div class="flex items-start justify-between flex-wrap gap-4">
            <div>
                <h1 class="font-heading text-5xl md:text-7xl font-black text-white tracking-tighter uppercase leading-[0.9]">
                    Intelligence<br/>Dashboard
                </h1>
                <p class="mt-6 text-gray-300 font-mono text-lg max-w-2xl">
                    Real-time quality metrics measuring the health of the Knowledge Graph,
                    Recommendations, and Learning Journeys. Self-scoring via BookOS Phase 2.5.
                </p>
            </div>
            <div class={`neo-card p-6 border-l-4 ${statusBg(overallPass)} min-w-[180px]`}>
                <p class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-2">Overall Status</p>
                <div class="flex items-center gap-3">
                    <span class={`w-4 h-4 rounded-full ${pulseBg(overallPass)} ${overallPass ? 'animate-pulse' : ''}`}></span>
                    <span class={`font-heading font-black text-2xl ${statusColor(overallPass)}`}>
                        {overallPass ? 'PASS' : 'FAIL'}
                    </span>
                </div>
                {evaluatedAt && (
                    <p class="font-mono text-xs text-gray-600 mt-3">
                        Last run:<br/>
                        <span class="text-gray-300">{new Date(evaluatedAt).toLocaleString()}</span>
                    </p>
                )}
                {!evaluatedAt && (
                    <p class="font-mono text-xs text-gray-600 mt-3">No evaluation run yet</p>
                )}
            </div>
        </div>
    </header>

    <!-- System Summary Cards -->
    <Section id="system-summary" title="System Overview" icon="◈">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
            <div class="neo-card p-6 text-center">
                <p class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-2">Nodes</p>
                <p class="font-heading font-black text-4xl text-white">{summary.total_nodes ?? '—'}</p>
            </div>
            <div class="neo-card p-6 text-center">
                <p class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-2">Edges</p>
                <p class="font-heading font-black text-4xl text-white">{summary.total_edges ?? '—'}</p>
            </div>
            <div class="neo-card p-6 text-center">
                <p class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-2">Journeys</p>
                <p class="font-heading font-black text-4xl text-white">{summary.journey_count ?? '—'}</p>
            </div>
            <div class="neo-card p-6 text-center">
                <p class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-2">Balance Score</p>
                <p class={`font-heading font-black text-4xl ${statusColor(journeysPass)}`}>
                    {summary.phase_balance_score ?? '—'}<span class="text-xl text-gray-400">/100</span>
                </p>
            </div>
        </div>
    </Section>

    <!-- Graph Health -->
    <Section id="graph-health" title="Graph Health" icon="G">
        <div class={`neo-card p-4 border-l-4 ${statusBg(graphPass)} mb-6 flex items-center justify-between`}>
            <p class="font-mono text-sm text-gray-300">Knowledge Graph structural integrity evaluation</p>
            <span class={`font-mono font-bold text-sm ${statusColor(graphPass)}`}>{statusLabel(graphPass)}</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {graphMetrics.map((m) => (
                <div class={`neo-card p-5 border-l-4 ${m.noThreshold ? 'border-l-[#333]' : statusBg(m.pass)}`}>
                    <p class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-1">{m.label}</p>
                    <p class={`font-heading font-black text-3xl ${m.noThreshold ? 'text-white' : statusColor(m.pass)}`}>{m.value}</p>
                    {!m.noThreshold && (
                        <p class="font-mono text-xs text-gray-600 mt-2">Target: {m.target}</p>
                    )}
                </div>
            ))}
        </div>
    </Section>

    <!-- Recommendation Health -->
    <Section id="recommendation-health" title="Recommendation Health" icon="R">
        <div class={`neo-card p-4 border-l-4 ${statusBg(recsPass)} mb-6 flex items-center justify-between`}>
            <p class="font-mono text-sm text-gray-300">Recommendation engine utilization and diversity</p>
            <span class={`font-mono font-bold text-sm ${statusColor(recsPass)}`}>{statusLabel(recsPass)}</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {recMetrics.map((m) => (
                <div class={`neo-card p-5 border-l-4 ${statusBg(m.pass)}`}>
                    <p class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-1">{m.label}</p>
                    <p class={`font-heading font-black text-3xl ${statusColor(m.pass)}`}>{m.value}</p>
                    <p class="font-mono text-xs text-gray-600 mt-2">Target: {m.target}</p>
                </div>
            ))}
            <!-- Full-width graph coverage bar -->
            <div class="neo-card p-5 md:col-span-2 border-l-4 border-l-[#333]">
                <p class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-3">Graph Coverage</p>
                <div class="w-full bg-[#111] h-4 border-2 border-[#333]">
                    <div
                        class="h-full bg-gradient-to-r from-[var(--color-secondary)] to-[#8B5CF6] transition-all"
                        style={`width: ${Math.min(summary.recommendation_coverage ?? 0, 100)}%`}
                    ></div>
                </div>
                <div class="flex justify-between mt-2">
                    <span class="font-mono text-xs text-gray-400">0%</span>
                    <span class="font-mono text-xs text-gray-300">{summary.recommendation_coverage ?? 0}% covered</span>
                    <span class="font-mono text-xs text-gray-400">100%</span>
                </div>
            </div>
        </div>
    </Section>

    <!-- Journey Health -->
    <Section id="journey-health" title="Journey Health" icon="J">
        <div class={`neo-card p-4 border-l-4 ${statusBg(journeysPass)} mb-6 flex items-center justify-between`}>
            <p class="font-mono text-sm text-gray-300">Learning journey quality and phase balance</p>
            <span class={`font-mono font-bold text-sm ${statusColor(journeysPass)}`}>{statusLabel(journeysPass)}</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {journeyMetrics.map((m) => (
                <div class={`neo-card p-5 border-l-4 ${statusBg(m.pass)}`}>
                    <p class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-1">{m.label}</p>
                    <p class={`font-heading font-black text-3xl ${statusColor(m.pass)}`}>{m.value}</p>
                    <p class="font-mono text-xs text-gray-600 mt-2">Target: {m.target}</p>
                </div>
            ))}
            <!-- Phase Balance Bar -->
            <div class="neo-card p-5 md:col-span-2 border-l-4 border-l-[#333]">
                <p class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-3">Phase Balance Score</p>
                <div class="w-full bg-[#111] h-4 border-2 border-[#333]">
                    <div
                        class={`h-full transition-all ${(summary.phase_balance_score ?? 0) >= 80 ? 'bg-success' : 'bg-warning'}`}
                        style={`width: ${Math.min(summary.phase_balance_score ?? 0, 100)}%`}
                    ></div>
                </div>
                <div class="flex justify-between mt-2">
                    <span class="font-mono text-xs text-gray-400">0</span>
                    <span class="font-mono text-xs text-gray-300">{summary.phase_balance_score ?? 0}/100</span>
                    <span class="font-mono text-xs text-gray-400">100</span>
                </div>
            </div>
        </div>
    </Section>

    <!-- Coverage Summary -->
    <Section id="coverage-metrics" title="Coverage Metrics" icon="C">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {[
                { label: 'Collection Coverage', value: summary.collection_coverage ?? 0, target: 80 },
                { label: 'Recommendation Coverage', value: summary.recommendation_coverage ?? 0, target: 70 },
                { label: 'Graph Utilization', value: summary.graph_utilization ?? 0, target: 70 },
            ].map((m) => {
                const pct = Math.min(m.value, 100);
                const passing = m.value >= m.target;
                return (
                    <div class="neo-card p-5">
                        <p class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-2">{m.label}</p>
                        <div class="flex items-end gap-3 mb-3">
                            <p class={`font-heading font-black text-4xl ${passing ? 'text-success' : 'text-[#EF4444]'}`}>{m.value}%</p>
                            <p class="font-mono text-xs text-gray-600 mb-1">target >{m.target}%</p>
                        </div>
                        <div class="w-full bg-[#111] h-2 border border-[#333]">
                            <div
                                class={`h-full ${passing ? 'bg-success' : 'bg-[#EF4444]'}`}
                                style={`width: ${pct}%`}
                            ></div>
                        </div>
                    </div>
                );
            })}
        </div>
    </Section>

    <!-- Footer hint -->
    <div class="mt-16 callout-box">
        <h4 class="font-heading font-bold text-white mb-2 uppercase">How to Update</h4>
        <p class="font-mono text-sm text-gray-300">
            Run <code class="bg-[#111] px-2 py-0.5 border border-[#333] text-secondary">bookos evaluate all</code> on your
            BookOS server, then <code class="bg-[#111] px-2 py-0.5 border border-[#333] text-secondary">bookos publish</code> to
            push the evaluation reports to KnowledgeRegistry. ReadRadar will rebuild automatically.
        </p>
    </div>
</Layout>
