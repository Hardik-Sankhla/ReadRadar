---
import Layout from '../../layouts/Layout.astro';
import runtimeData from '../../data/runtime.json';

const heartbeat = runtimeData.heartbeat || {};
const metrics = runtimeData.metrics || {};
const state = runtimeData.state || {};

const statusColor = heartbeat.status === 'running' || heartbeat.status === 'healthy' || heartbeat.status === 'sleeping' 
  ? 'bg-green-500' 
  : 'bg-red-500';

const statusText = heartbeat.status ? heartbeat.status.toUpperCase() : 'UNKNOWN';

const formatDate = (dateString: string) => {
  if (!dateString) return 'Never';
  return new Date(dateString).toLocaleString();
};
---

<Layout title="Runtime Status | ReadRadar">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
      <div>
        <h1 class="text-3xl font-bold mb-2 text-white">BookOS Runtime Status</h1>
        <p class="text-gray-400">Production Control Plane</p>
      </div>
      <div class="flex items-center space-x-2 bg-gray-800 px-4 py-2 rounded-full border border-gray-700 shadow-sm self-start md:self-auto">
        <span class={`w-3 h-3 rounded-full ${statusColor} animate-pulse`}></span>
        <span class="text-sm font-medium tracking-wider text-white">{statusText}</span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-sm transition-all hover:border-gray-600">
        <h3 class="text-gray-400 text-sm font-medium mb-1">Uptime</h3>
        <p class="text-2xl font-bold text-white">{heartbeat.uptime_hours || 0} <span class="text-sm font-normal text-gray-500">hours</span></p>
      </div>
      <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-sm transition-all hover:border-gray-600">
        <h3 class="text-gray-400 text-sm font-medium mb-1">Success Rate</h3>
        <p class="text-2xl font-bold text-white">
          {(heartbeat.successful_runs || 0) + (heartbeat.failed_runs || 0) > 0 
            ? Math.round(((heartbeat.successful_runs || 0) / ((heartbeat.successful_runs || 0) + (heartbeat.failed_runs || 0))) * 100)
            : 0}%
        </p>
      </div>
      <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-sm transition-all hover:border-gray-600">
        <h3 class="text-gray-400 text-sm font-medium mb-1">Last Run</h3>
        <p class="text-sm font-medium text-white truncate" title={formatDate(heartbeat.last_run)}>{formatDate(heartbeat.last_run)}</p>
      </div>
      <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-sm transition-all hover:border-gray-600">
        <h3 class="text-gray-400 text-sm font-medium mb-1">Next Run</h3>
        <p class="text-sm font-medium text-white truncate" title={formatDate(heartbeat.next_run)}>{formatDate(heartbeat.next_run)}</p>
      </div>
    </div>

    <h2 class="text-2xl font-semibold mb-4 mt-12 text-white">Registry Metrics</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-gray-800/50 p-5 rounded-lg border border-gray-700/50 shadow-inner">
        <div class="text-gray-400 text-xs uppercase tracking-wider mb-2 font-medium">Total Nodes</div>
        <div class="text-2xl font-bold text-blue-400">{metrics.total_nodes || 0}</div>
      </div>
      <div class="bg-gray-800/50 p-5 rounded-lg border border-gray-700/50 shadow-inner">
        <div class="text-gray-400 text-xs uppercase tracking-wider mb-2 font-medium">Total Edges</div>
        <div class="text-2xl font-bold text-purple-400">{metrics.total_edges || 0}</div>
      </div>
      <div class="bg-gray-800/50 p-5 rounded-lg border border-gray-700/50 shadow-inner">
        <div class="text-gray-400 text-xs uppercase tracking-wider mb-2 font-medium">Skills</div>
        <div class="text-2xl font-bold text-yellow-400">{metrics.skills || 0}</div>
      </div>
      <div class="bg-gray-800/50 p-5 rounded-lg border border-gray-700/50 shadow-inner">
        <div class="text-gray-400 text-xs uppercase tracking-wider mb-2 font-medium">Collections</div>
        <div class="text-2xl font-bold text-green-400">{metrics.collections || 0}</div>
      </div>
    </div>

    <div class="bg-gray-800 rounded-xl border border-gray-700 overflow-hidden shadow-sm mt-8">
      <div class="px-6 py-4 border-b border-gray-700 bg-gray-800/80">
        <h3 class="font-medium text-gray-200">System Health</h3>
      </div>
      <div class="p-6">
        <div class="space-y-4">
          <div class="flex justify-between items-center border-b border-gray-700/50 pb-4 hover:bg-gray-750 transition-colors px-2 -mx-2 rounded">
            <span class="text-gray-400">Orphan Rate</span>
            <span class="font-medium text-white">{metrics.orphan_rate !== undefined ? metrics.orphan_rate + '%' : 'N/A'}</span>
          </div>
          <div class="flex justify-between items-center border-b border-gray-700/50 pb-4 hover:bg-gray-750 transition-colors px-2 -mx-2 rounded">
            <span class="text-gray-400">Collection Coverage</span>
            <span class="font-medium text-white">{metrics.coverage !== undefined ? metrics.coverage + '%' : 'N/A'}</span>
          </div>
          <div class="flex justify-between items-center hover:bg-gray-750 transition-colors px-2 -mx-2 rounded pb-2">
            <span class="text-gray-400">Last Deployment</span>
            <span class="font-medium text-white">{formatDate(heartbeat.last_publish)}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
