---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import Statistics from '../components/ui/Statistics.astro';
import { Badge } from '../components/ui/Badge';
import { ResourceTable } from '../components/ui/Table';

import booksData from '../data/books.json';
import domainsData from '../data/domains.json';
import collectionsData from '../data/collections.json';
import authorsData from '../data/authors.json';

import type { Book, Domain, Collection, Author } from '../types';

const books = booksData as Book[];
const domains = domainsData as Domain[];
const collections = collectionsData as Collection[];
const authors = authorsData as Author[];

// Process data for homepage
const trendingBooks = [...books].sort((a, b) => b.trend_score - a.trend_score).slice(0, 3);
const recentlyAdded = [...books].sort((a, b) => new Date(b.date_added).getTime() - new Date(a.date_added).getTime()).slice(0, 3);
const popularDomains = [...domains].filter(d => d.trending).slice(0, 6);
const featuredCollections = [...collections].slice(0, 6);
---

<Layout title="ReadRadar | The Intelligence Layer for Technical Books">
    <Hero />
    
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-24">
        <Statistics value={books.length.toString()} label="Resources" />
        <Statistics value={authors.length.toString()} label="Authors" color="text-[#06B6D4]" />
        <Statistics value={domains.length.toString()} label="Domains" color="text-[#E11D48]" />
        <Statistics value="6m ago" label="Updated" color="text-[#10B981]" />
    </div>

    <!-- Minimal Search Entry Point (navigates to discover) -->
    <Section id="search" title="Search Everything" icon="?">
        <form action="/discover" method="get" class="flex gap-4 max-w-2xl">
            <input 
                type="text" 
                name="q"
                placeholder="Search books, authors, domains..." 
                class="bg-[#171717] border-2 border-[#333333] p-4 text-white focus:outline-none focus:border-[#7C3AED] w-full font-mono text-lg shadow-[6px_6px_0px_0px_#333333] focus:shadow-[6px_6px_0px_0px_#7C3AED] transition-all"
            />
            <button type="submit" class="bg-gradient-to-r from-[#7C3AED] to-[#5B21B6] text-white font-bold font-heading px-8 py-4 uppercase shadow-[6px_6px_0px_0px_#FFFFFF] hover:shadow-[2px_2px_0px_0px_#FFFFFF] hover:translate-y-1 hover:translate-x-1 transition-all border-2 border-white">
                Search
            </button>
        </form>
    </Section>

    <Section id="trending" title="Trending This Week" icon="↑" className="mt-24">
        <ResourceTable data={trendingBooks} client:load />
    </Section>

    <Section id="recent" title="Recently Discovered" icon="+" className="mt-24">
        <ResourceTable data={recentlyAdded} client:load />
    </Section>

    <Section id="domains" title="Popular Domains" icon="D" className="mt-24">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {popularDomains.map(domain => (
                <Card href={`/discover?domain=${encodeURIComponent(domain.name)}`} className="group hover:border-[#7C3AED]">
                    <div class="flex justify-between items-start mb-4">
                        <h3 class="font-heading font-bold text-xl text-white group-hover:text-[#7C3AED] transition-colors">{domain.name}</h3>
                        <Badge variant="solid">{domain.resource_count} items</Badge>
                    </div>
                    <p class="text-sm text-gray-400 line-clamp-2">{domain.description}</p>
                </Card>
            ))}
        </div>
    </Section>

    <Section id="collections" title="Featured Collections" icon="C" className="mt-24">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {featuredCollections.map(collection => (
                <Card href={`/collections`} className="group hover:border-[#06B6D4]">
                    <h3 class="font-heading font-bold text-xl text-white group-hover:text-[#06B6D4] transition-colors mb-2">{collection.title}</h3>
                    <p class="text-sm text-gray-400 mb-4">{collection.description}</p>
                    <div class="flex justify-between items-center mt-auto">
                        <span class="text-xs font-mono text-gray-500">Curator: {collection.curator}</span>
                        <Badge>{collection.resources.length} resources</Badge>
                    </div>
                </Card>
            ))}
        </div>
    </Section>
    
    <Section id="how-it-works" title="How ReadRadar Works" icon="⚙" className="mt-24">
        <div class="neo-card p-12 text-center border-l-4 border-l-[#8B5CF6]">
            <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-8 font-heading text-xl md:text-2xl font-bold uppercase tracking-widest text-gray-400">
                <div class="text-white bg-[#333333] px-6 py-3 border-2 border-white shadow-[4px_4px_0px_0px_#FFFFFF]">Agent</div>
                <span class="text-[#7C3AED] transition-all duration-300 group-hover:scale-110">→</span>
                <div class="text-white bg-[#333333] px-6 py-3 border-2 border-white shadow-[4px_4px_0px_0px_#FFFFFF]">Discovery</div>
                <span class="text-[#7C3AED] transition-all duration-300 group-hover:scale-110">→</span>
                <div class="text-white bg-[#333333] px-6 py-3 border-2 border-white shadow-[4px_4px_0px_0px_#FFFFFF]">Validation</div>
                <span class="text-[#7C3AED] transition-all duration-300 group-hover:scale-110">→</span>
                <div class="text-white bg-[#333333] px-6 py-3 border-2 border-white shadow-[4px_4px_0px_0px_#FFFFFF]">Knowledge</div>
            </div>
            <p class="mt-12 text-gray-400 font-mono text-sm max-w-2xl mx-auto">
                ReadRadar is entirely static. An autonomous agent continuously scans the internet for new technical resources, validates them, and updates the JSON knowledge base. This website simply reflects the current state of that knowledge base.
            </p>
        </div>
    </Section>

    <Section id="recently-updated" title="Intelligence Timeline" icon="⏱" className="mt-24">
        <div class="neo-card p-0 overflow-hidden">
            <table class="w-full text-left text-sm font-mono">
                <tbody>
                    <tr class="border-b border-[#333333] hover:bg-[#262626] transition-colors">
                        <td class="p-4 text-gray-500 w-32">Yesterday</td>
                        <td class="p-4 text-[#10B981] font-bold w-24">Added</td>
                        <td class="p-4 text-white">AI Engineering Domain</td>
                    </tr>
                    <tr class="border-b border-[#333333] hover:bg-[#262626] transition-colors">
                        <td class="p-4 text-gray-500">2 hours ago</td>
                        <td class="p-4 text-[#10B981] font-bold">Added</td>
                        <td class="p-4 text-white">MCP Guide (Anthropic)</td>
                    </tr>
                    <tr class="hover:bg-[#262626] transition-colors">
                        <td class="p-4 text-gray-500">6 hours ago</td>
                        <td class="p-4 text-[#7C3AED] font-bold">Updated</td>
                        <td class="p-4 text-white">Chip Huyen Machine Learning Collection</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </Section>

    <Section id="community-picks" title="Community Picks" icon="♥" className="mt-24">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <Card href="#" className="group hover:border-[#E11D48]">
                <h3 class="font-heading font-bold text-xl text-white group-hover:text-[#E11D48] transition-colors mb-2">Designing Data-Intensive Applications</h3>
                <p class="text-sm text-gray-400 mb-4">The absolute bible for backend engineers.</p>
                <Badge variant="solid">Martin Kleppmann</Badge>
            </Card>
            <Card href="#" className="group hover:border-[#E11D48]">
                <h3 class="font-heading font-bold text-xl text-white group-hover:text-[#E11D48] transition-colors mb-2">Understanding Deep Learning</h3>
                <p class="text-sm text-gray-400 mb-4">A visual, intuitive guide to modern neural networks.</p>
                <Badge variant="solid">Simon J.D. Prince</Badge>
            </Card>
        </div>
    </Section>

    <Section id="open-source" title="Open Source" icon="{" className="mt-24">
        <div class="neo-card p-8 grid grid-cols-2 md:grid-cols-5 gap-6 text-center">
            <div>
                <div class="font-heading text-3xl font-bold text-white mb-1">1.2k</div>
                <div class="font-mono text-xs text-gray-500 uppercase">⭐ Stars</div>
            </div>
            <div>
                <div class="font-heading text-3xl font-bold text-white mb-1">142</div>
                <div class="font-mono text-xs text-gray-500 uppercase">🍴 Forks</div>
            </div>
            <div>
                <div class="font-heading text-3xl font-bold text-white mb-1">12</div>
                <div class="font-mono text-xs text-gray-500 uppercase">👥 Contributors</div>
            </div>
            <div>
                <div class="font-heading text-3xl font-bold text-[#E11D48] mb-1">4</div>
                <div class="font-mono text-xs text-gray-500 uppercase">🐞 Issues</div>
            </div>
            <div>
                <div class="font-heading text-3xl font-bold text-white mb-1">MIT</div>
                <div class="font-mono text-xs text-gray-500 uppercase">📄 License</div>
            </div>
        </div>
    </Section>

    <Section id="roadmap" title="Development Roadmap" icon="🗺" className="mt-24">
        <div class="flex flex-col md:flex-row gap-4 font-mono text-sm">
            <div class="flex-1 neo-card p-6 border-l-4 border-l-[#10B981]">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-white font-bold">Phase 1</span>
                    <span class="text-[#10B981] font-bold">✓</span>
                </div>
                <span class="text-gray-400">Frontend UI</span>
            </div>
            <div class="flex-1 neo-card p-6 border-l-4 border-l-[#F59E0B]">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-white font-bold">Phase 2</span>
                    <span class="text-[#F59E0B] font-bold">⏳</span>
                </div>
                <span class="text-gray-400">BookOS Pipeline</span>
            </div>
            <div class="flex-1 neo-card p-6 border-l-4 border-l-[#333333]">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-gray-500 font-bold">Phase 3</span>
                    <span class="text-gray-500 font-bold">⏳</span>
                </div>
                <span class="text-gray-600">Autonomous Agents</span>
            </div>
            <div class="flex-1 neo-card p-6 border-l-4 border-l-[#333333]">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-gray-500 font-bold">Phase 4</span>
                    <span class="text-gray-500 font-bold">⏳</span>
                </div>
                <span class="text-gray-600">Personalized Recs</span>
            </div>
        </div>
    </Section>

    <Section id="changelog" title="Changelog Preview" icon="v" className="mt-24">
        <div class="neo-card p-8">
            <h3 class="font-heading text-2xl font-bold text-white mb-4">v1.1 <span class="text-sm font-mono text-gray-500 font-normal ml-2">Today</span></h3>
            <ul class="space-y-2 font-mono text-sm">
                <li class="flex items-center gap-3"><span class="px-2 py-0.5 bg-[#10B981]/20 text-[#10B981] text-xs font-bold border border-[#10B981]/50">ADDED</span> <span class="text-gray-300">25 new Books across AI and Systems Engineering.</span></li>
                <li class="flex items-center gap-3"><span class="px-2 py-0.5 bg-[#10B981]/20 text-[#10B981] text-xs font-bold border border-[#10B981]/50">ADDED</span> <span class="text-gray-300">New Domains: Autonomous Agents, MLOps.</span></li>
                <li class="flex items-center gap-3"><span class="px-2 py-0.5 bg-[#10B981]/20 text-[#10B981] text-xs font-bold border border-[#10B981]/50">ADDED</span> <span class="text-gray-300">New Collections: Anthropic MCP Guides.</span></li>
                <li class="flex items-center gap-3"><span class="px-2 py-0.5 bg-[#7C3AED]/20 text-[#7C3AED] text-xs font-bold border border-[#7C3AED]/50">IMPROVED</span> <span class="text-gray-300">Cmd+K global search shortcut.</span></li>
            </ul>
        </div>
    </Section>

</Layout>
