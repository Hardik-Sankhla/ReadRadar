---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import Statistics from '../components/ui/Statistics.astro';
import { Badge } from '../components/ui/Badge';
import { ResourceTable } from '../components/ui/Table';

import resourcesData from '../data/resources.json';
import collectionsData from '../data/collections.json';
import journeysData from '../data/journeys.json';

import type { Resource, Collection } from '../types';

const resources = resourcesData as Resource[];
const collections = collectionsData as Collection[];
const journeys = journeysData as any[];

// Process data for homepage
const trendingResources = [...resources].sort((a, b) => b.trend_score - a.trend_score).slice(0, 5);
const recentlyAdded = [...resources].sort((a, b) => new Date(b.date_added).getTime() - new Date(a.date_added).getTime()).slice(0, 5);
const featuredCollections = [...collections].slice(0, 6);
---

<Layout title="ReadRadar — What do you want to become?">
    <!-- GOAL-FIRST HERO -->
    <Hero />

    <!-- LIVE STATS STRIP -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-24">
        <Statistics value={resources.length.toString()} label="Resources" />
        <Statistics value={collections.length.toString()} label="Collections" color="text-[#06B6D4]" />
        <Statistics value={journeys.length.toString()} label="Journeys" color="text-[#8B5CF6]" />
        <Statistics value="Live" label="Knowledge Graph" color="text-[#10B981]" />
    </div>

    <!-- TRENDING RESOURCES -->
    <Section id="trending" title="Trending This Week" icon="↑">
        <ResourceTable data={trendingResources} client:load />
    </Section>

    <!-- HOW IT WORKS -->
    <Section id="how-it-works" title="How ReadRadar Works" icon="⚙" className="mt-24">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="neo-card p-8 border-l-4 border-l-[#7C3AED]">
                <div class="font-heading font-black text-4xl text-[#7C3AED] mb-4">01</div>
                <h3 class="font-heading font-bold text-xl text-white mb-2">Choose a Goal</h3>
                <p class="font-mono text-sm text-gray-400">
                    Select what you want to become. ReadRadar maps the knowledge graph to your career objective.
                </p>
            </div>
            <div class="neo-card p-8 border-l-4 border-l-[#06B6D4]">
                <div class="font-heading font-black text-4xl text-[#06B6D4] mb-4">02</div>
                <h3 class="font-heading font-bold text-xl text-white mb-2">Follow a Journey</h3>
                <p class="font-mono text-sm text-gray-400">
                    Get a structured path across books, repos, papers, and models — ordered by phase and difficulty.
                </p>
            </div>
            <div class="neo-card p-8 border-l-4 border-l-[#10B981]">
                <div class="font-heading font-black text-4xl text-[#10B981] mb-4">03</div>
                <h3 class="font-heading font-bold text-xl text-white mb-2">Build & Ship</h3>
                <p class="font-mono text-sm text-gray-400">
                    Each journey includes real project suggestions drawn from the highest-quality repositories.
                </p>
            </div>
        </div>
    </Section>

    <!-- FEATURED COLLECTIONS -->
    {featuredCollections.length > 0 && (
        <Section id="collections" title="Curated Collections" icon="C" className="mt-24">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {featuredCollections.map((collection: any) => (
                    <Card href={`${import.meta.env.BASE_URL}/collections`.replace(/\/\/+/g, '/')} className="group hover:border-[#06B6D4]">
                        <h3 class="font-heading font-bold text-xl text-white group-hover:text-[#06B6D4] transition-colors mb-2">{collection.title}</h3>
                        <p class="text-sm text-gray-400 mb-4 flex-grow">{collection.description}</p>
                        <div class="flex justify-end items-center mt-auto">
                            <span class="text-[#06B6D4] font-bold text-sm group-hover:translate-x-1 transition-transform">Explore →</span>
                        </div>
                    </Card>
                ))}
            </div>
        </Section>
    )}

    <!-- RECENTLY DISCOVERED -->
    <Section id="recent" title="Recently Discovered" icon="+" className="mt-24">
        <ResourceTable data={recentlyAdded} client:load />
    </Section>

    <!-- PIPELINE EXPLAINER -->
    <Section id="pipeline" title="The Intelligence Pipeline" icon="⇌" className="mt-24">
        <div class="neo-card p-10 border-l-4 border-l-[#8B5CF6] overflow-hidden">
            <div class="flex flex-col md:flex-row items-center justify-center gap-3 md:gap-6 font-heading text-lg md:text-xl font-bold uppercase tracking-widest text-gray-400 flex-wrap">
                {[
                    { label: "BookOS", color: "#7C3AED" },
                    { label: "Discovery", color: "#06B6D4" },
                    { label: "Graph", color: "#8B5CF6" },
                    { label: "Journeys", color: "#10B981" },
                    { label: "ReadRadar", color: "#E11D48" },
                ].map((step, i) => (
                    <>
                        <div
                            class="px-5 py-2.5 border-2 border-white font-black text-white"
                            style={`background: ${step.color}22; border-color: ${step.color}44; color: ${step.color};`}
                        >
                            {step.label}
                        </div>
                        {i < 4 && <span class="text-[#333] hidden md:block">→</span>}
                    </>
                ))}
            </div>
            <p class="mt-10 text-gray-400 font-mono text-sm max-w-2xl mx-auto text-center">
                BookOS continuously scans GitHub, ArXiv, and Hugging Face. Resources are normalized into a live knowledge graph, enriched with relationships, clustered into collections, and assembled into learning journeys — then rendered here.
            </p>
        </div>
    </Section>

    <!-- ROADMAP -->
    <Section id="roadmap" title="Platform Roadmap" icon=">" className="mt-24">
        <div class="flex flex-col md:flex-row gap-4 font-mono text-sm">
            {[
                { phase: "Phase 1", label: "Frontend UI", done: true },
                { phase: "Phase 2", label: "BookOS Pipeline", done: true },
                { phase: "Phase 3", label: "Goal Intelligence", current: true },
                { phase: "Phase 4", label: "Skill Graph", done: false },
                { phase: "Phase 5", label: "Career OS", done: false },
            ].map((item) => (
                <div class={`flex-1 neo-card p-6 border-l-4 ${item.done ? 'border-l-[#10B981]' : item.current ? 'border-l-[#F59E0B]' : 'border-l-[#333333]'}`}>
                    <div class="flex justify-between items-center mb-2">
                        <span class={`font-bold ${item.done || item.current ? 'text-white' : 'text-gray-500'}`}>{item.phase}</span>
                        <span class={item.done ? 'text-[#10B981]' : item.current ? 'text-[#F59E0B]' : 'text-gray-600'}>
                            {item.done ? '✓' : item.current ? '⏳' : '·'}
                        </span>
                    </div>
                    <span class={item.done || item.current ? 'text-gray-400' : 'text-gray-600'}>{item.label}</span>
                </div>
            ))}
        </div>
    </Section>
</Layout>
