---
import Layout from '../layouts/Layout.astro';
import Section from '../components/ui/Section.astro';
---

<Layout title="System Status | ReadRadar">
    <header class="mb-16 pb-8 border-b-2 border-[#222]">
        <a href={`${import.meta.env.BASE_URL}/`.replace(/\/\/+/g, '/')} class="font-mono text-xs text-gray-500 hover:text-white transition-colors mb-6 inline-flex items-center gap-2">
            ← Home
        </a>
        <h1 class="font-heading text-5xl md:text-7xl font-black text-white tracking-tighter uppercase leading-[0.9] mt-4">
            System<br/>Status
        </h1>
        <p class="mt-6 text-gray-400 font-mono text-lg max-w-2xl">
            Real-time health monitoring of the ReadRadar infrastructure and autonomous BookOS agents.
        </p>
    </header>

    <Section id="status" title="Service Health" icon="✓">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
            <div class="neo-card p-6 border-l-4 border-l-[#10B981] flex justify-between items-center">
                <div>
                    <h3 class="font-heading font-bold text-xl text-white">ReadRadar Frontend</h3>
                    <p class="font-mono text-xs text-gray-500 mt-1">Astro + GitHub Pages CDN</p>
                </div>
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-[#10B981] animate-pulse"></span>
                    <span class="font-mono text-sm font-bold text-[#10B981]">Online</span>
                </div>
            </div>

            <div class="neo-card p-6 border-l-4 border-l-[#10B981] flex justify-between items-center">
                <div>
                    <h3 class="font-heading font-bold text-xl text-white">Knowledge Graph</h3>
                    <p class="font-mono text-xs text-gray-500 mt-1">73 nodes · 787 edges · 5 collections</p>
                </div>
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-[#10B981] animate-pulse"></span>
                    <span class="font-mono text-sm font-bold text-[#10B981]">Healthy</span>
                </div>
            </div>

            <div class="neo-card p-6 border-l-4 border-l-[#10B981] flex justify-between items-center">
                <div>
                    <h3 class="font-heading font-bold text-xl text-white">BookOS Discovery</h3>
                    <p class="font-mono text-xs text-gray-500 mt-1">Crawling GitHub · ArXiv · HuggingFace</p>
                </div>
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-[#10B981] animate-pulse"></span>
                    <span class="font-mono text-sm font-bold text-[#10B981]">Running</span>
                </div>
            </div>

            <div class="neo-card p-6 border-l-4 border-l-[#10B981] flex justify-between items-center">
                <div>
                    <h3 class="font-heading font-bold text-xl text-white">CI/CD Pipeline</h3>
                    <p class="font-mono text-xs text-gray-500 mt-1">GitHub Actions → GitHub Pages</p>
                </div>
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-[#10B981]"></span>
                    <span class="font-mono text-sm font-bold text-[#10B981]">Passing</span>
                </div>
            </div>
        </div>

        <div class="callout-box">
            <h4 class="font-heading font-bold text-white mb-2 uppercase">Incidents</h4>
            <p class="text-sm text-gray-400">No incidents reported in the last 30 days. All systems operational.</p>
        </div>
    </Section>

    <Section id="links" title="Quick Links" icon="→">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <a href={`${import.meta.env.BASE_URL}/status/intelligence`.replace(/\/\/+/g, '/')} class="neo-card p-6 hover:border-[#06B6D4] group transition-colors">
                <h3 class="font-heading font-bold text-white group-hover:text-[#06B6D4] transition-colors mb-2">Intelligence Dashboard</h3>
                <p class="font-mono text-xs text-gray-500">Knowledge graph quality metrics and evaluation scores</p>
            </a>
            <a href="https://github.com/Hardik-Sankhla/ReadRadar/actions" target="_blank" rel="noopener noreferrer" class="neo-card p-6 hover:border-[#7C3AED] group transition-colors">
                <h3 class="font-heading font-bold text-white group-hover:text-[#7C3AED] transition-colors mb-2">GitHub Actions</h3>
                <p class="font-mono text-xs text-gray-500">Live CI/CD pipeline runs and deploy logs</p>
            </a>
            <a href="https://github.com/Hardik-Sankhla/KnowledgeRegistry" target="_blank" rel="noopener noreferrer" class="neo-card p-6 hover:border-[#10B981] group transition-colors">
                <h3 class="font-heading font-bold text-white group-hover:text-[#10B981] transition-colors mb-2">KnowledgeRegistry</h3>
                <p class="font-mono text-xs text-gray-500">Raw data source — nodes, edges, and evaluation reports</p>
            </a>
        </div>
    </Section>
</Layout>
