---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import { Badge } from '../../components/ui/Badge';

import journeysData from '../../data/journeys.json';
---

<Layout title="Learning Journeys | ReadRadar">
    <Section id="journeys-header" title="Learning Journeys" icon="J">
        <p class="font-mono text-gray-400 max-w-2xl mt-4">
            Goal-driven learning roadmaps structured logically with estimated timelines, generated from the KnowledgeRegistry graph.
        </p>
    </Section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {journeysData.map((journey: any) => {
            const meta = journey.metadata || {};
            const hours = meta.total_estimated_hours || 0;
            const phases = meta.phases?.length || 0;
            const baseUrl = import.meta.env.BASE_URL;
            const journeyUrl = `${baseUrl}/journeys/${journey.id}`.replace(/\/\/+/g, '/');

            return (
                <Card href={journeyUrl} className="group hover:border-[#06B6D4] flex flex-col h-full">
                    <div class="flex flex-col mb-6">
                        <h3 class="font-heading font-bold text-3xl text-white group-hover:text-[#06B6D4] transition-colors">{journey.title}</h3>
                    </div>
                    
                    <p class="text-gray-400 text-lg mb-8 flex-grow border-l-4 border-[#333333] pl-4">{journey.description}</p>
                    
                    <div class="mt-auto bg-[#0A0A0A] p-4 border-2 border-[#333333] flex flex-wrap gap-4 justify-between items-center">
                        <div class="flex flex-wrap items-center gap-2 sm:gap-4">
                            <Badge variant="solid">{phases} Phases</Badge>
                            <Badge variant="outline">{hours}h Estimated</Badge>
                        </div>
                        <span class="text-[#06B6D4] font-bold group-hover:translate-x-1 transition-transform">Start Journey →</span>
                    </div>
                </Card>
            );
        })}
    </div>
</Layout>
