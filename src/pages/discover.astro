---
import Layout from '../layouts/Layout.astro';
import Section from '../components/ui/Section.astro';
import DiscoverApp from '../components/ui/DiscoverApp';

import booksData from '../data/books.json';
import domainsData from '../data/domains.json';
import type { Book, Domain } from '../types';

const books = booksData as Book[];
const domains = domainsData as Domain[];
---

<Layout title="Discover | ReadRadar">
    <Section id="discover-header" title="Discover Intelligence" icon="*">
        <p class="font-mono text-gray-400 max-w-2xl mt-4">
            Browse the complete knowledge base. All resources have been verified by the Agent Layer.
        </p>
    </Section>

    <DiscoverApp client:load books={books} domains={domains} />
</Layout>
