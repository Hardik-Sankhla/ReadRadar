---
import Layout from '../layouts/Layout.astro';
import Section from '../components/ui/Section.astro';
import DiscoverApp from '../components/ui/DiscoverApp';

import resourcesData from '../data/resources.json';
import domainsData from '../data/domains.json';
import collectionsData from '../data/collections.json';
import edgesData from '../data/edges.json';
import type { Resource, Domain } from '../types';

const resources = resourcesData as Resource[];
const domains = domainsData as Domain[];
const collections = collectionsData as any[];
const edges = edgesData as any[];
---

<Layout title="Discover | ReadRadar">
    <Section id="discover-header" title="Resource Library" icon="*">
        <p class="font-mono text-gray-400 max-w-2xl mt-4">
            Browse the complete knowledge base. All resources have been verified by the Agent Layer.
        </p>
    </Section>

    <DiscoverApp client:load resources={resources} domains={domains} collections={collections} edges={edges} />
</Layout>
