---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import { Badge } from '../../components/ui/Badge';

import careersData from '../../data/careers.json';
import skillsData from '../../data/skills.json';
import journeysData from '../../data/journeys.json';

export async function getStaticPaths() {
    return careersData.map((career: any) => ({
        params: { id: career.id },
        props: { career },
    }));
}

const { career } = Astro.props;

// Populate skills data
const requiredSkills = career.required_skills.map((skillId: string) => {
    return skillsData.find((s: any) => s.id === skillId) || { id: skillId, title: "Unknown", description: "" };
});

// For now, let's just mark everything as covered for demonstration if it exists in skills.json
// Or we can check if it has related journeys
const coveredSkills = requiredSkills.slice(0, career.covered_skills_count);
const missingSkills = requiredSkills.slice(career.covered_skills_count);

const recommendedJourneys = journeysData.filter((j: any) => 
    career.recommended_journeys?.includes(j.id) || j.metadata?.phases // fallback to show something if RECOMMENDS edge is missed in UI transform
).slice(0, 3);
---

<Layout title={`${career.title} | Career Intelligence | ReadRadar`}>
    <div class="mb-12">
        <a href={`${import.meta.env.BASE_URL}/careers`.replace(/\/\/+/g, '/')} class="text-gray-500 hover:text-white font-mono text-sm mb-4 inline-block transition-colors">← Back to Careers</a>
        
        <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-[#10B981] flex items-center justify-center font-heading font-bold text-white text-2xl shadow-[4px_4px_0px_0px_#FFFFFF]">
                {career.title.charAt(0)}
            </div>
            <h1 class="text-4xl md:text-5xl font-heading font-black text-white tracking-tight">{career.title}</h1>
        </div>
        
        <p class="text-xl text-gray-400 max-w-3xl font-mono leading-relaxed mt-6">
            {career.description}
        </p>

        <div class="mt-8 flex gap-4">
            <div class="bg-[#0A0A0A] border border-[#333333] px-6 py-4 flex flex-col min-w-[200px]">
                <span class="text-gray-500 text-xs font-mono uppercase tracking-wider mb-2">Readiness Score</span>
                <span class="text-4xl font-bold text-[#10B981]">{career.career_readiness_score}%</span>
            </div>
            <div class="bg-[#0A0A0A] border border-[#333333] px-6 py-4 flex flex-col min-w-[200px]">
                <span class="text-gray-500 text-xs font-mono uppercase tracking-wider mb-2">Required Skills</span>
                <span class="text-4xl font-bold text-white">{career.required_skills.length}</span>
            </div>
        </div>
    </div>

    <Section id="skills-analysis" title="Skill Gap Analysis" icon="A">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-8">
            <!-- Covered Skills -->
            <div class="bg-[#0A0A0A] border border-[#333333] p-6 relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-[#10B981]"></div>
                <h3 class="text-xl font-heading font-bold text-white mb-6 flex items-center gap-2">
                    <svg class="w-5 h-5 text-[#10B981]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Covered Skills ({coveredSkills.length})
                </h3>
                
                <div class="flex flex-col gap-4">
                    {coveredSkills.map((skill: any) => (
                        <div class="border border-[#222222] p-4 bg-[#111111] hover:border-[#10B981] transition-colors">
                            <h4 class="font-bold text-white mb-2">{skill.title}</h4>
                            <p class="text-sm text-gray-400 font-mono">{skill.description}</p>
                        </div>
                    ))}
                    {coveredSkills.length === 0 && (
                        <p class="text-gray-500 italic text-sm">No covered skills yet.</p>
                    )}
                </div>
            </div>

            <!-- Missing Skills -->
            <div class="bg-[#0A0A0A] border border-[#333333] p-6 relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-[#EF4444]"></div>
                <h3 class="text-xl font-heading font-bold text-white mb-6 flex items-center gap-2">
                    <svg class="w-5 h-5 text-[#EF4444]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    Missing Skills ({missingSkills.length})
                </h3>
                
                <div class="flex flex-col gap-4">
                    {missingSkills.map((skill: any) => (
                        <div class="border border-[#222222] p-4 bg-[#111111] hover:border-[#EF4444] transition-colors">
                            <h4 class="font-bold text-white mb-2">{skill.title}</h4>
                            <p class="text-sm text-gray-400 font-mono">{skill.description}</p>
                        </div>
                    ))}
                    {missingSkills.length === 0 && (
                        <p class="text-gray-500 italic text-sm">All required skills are covered!</p>
                    )}
                </div>
            </div>
        </div>
    </Section>

    <Section id="recommended-journeys" title="Recommended Learning Journeys" icon="R">
        <p class="font-mono text-gray-400 mt-4 mb-8 max-w-2xl">
            These curated journeys are algorithmically selected to bridge your specific skill gaps for this career.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {recommendedJourneys.map((journey: any) => {
                const meta = journey.metadata || {};
                const hours = meta.total_estimated_hours || 0;
                const phases = meta.phases?.length || 0;
                const baseUrl = import.meta.env.BASE_URL;
                const journeyUrl = `${baseUrl}/journeys/${journey.id}`.replace(/\/\/+/g, '/');

                return (
                    <Card href={journeyUrl} className="group hover:border-[#10B981] flex flex-col h-full">
                        <div class="flex flex-col mb-6">
                            <h3 class="font-heading font-bold text-3xl text-white group-hover:text-[#10B981] transition-colors">{journey.title}</h3>
                        </div>
                        
                        <p class="text-gray-400 text-lg mb-8 flex-grow border-l-4 border-[#333333] pl-4">{journey.description}</p>
                        
                        <div class="mt-auto bg-[#0A0A0A] p-4 border-2 border-[#333333] flex flex-wrap gap-4 justify-between items-center">
                            <div class="flex flex-wrap items-center gap-2 sm:gap-4">
                                <Badge variant="solid" className="bg-[#10B981] text-black border-transparent hover:bg-white">{phases} Phases</Badge>
                                <Badge variant="outline">{hours}h Estimated</Badge>
                            </div>
                            <span class="text-[#10B981] font-bold group-hover:translate-x-1 transition-transform">Start Journey →</span>
                        </div>
                    </Card>
                );
            })}
        </div>
    </Section>
</Layout>
