---
import Layout from '../layouts/Layout.astro';
import Section from '../components/ui/Section.astro';
import BarChart from '../components/ui/BarChart.astro';
import Statistics from '../components/ui/Statistics.astro';
import { ResourceTable } from '../components/ui/Table';

import resourcesData from '../data/resources.json';
import type { Resource } from '../types';

const resources = resourcesData as Resource[];
const trendingResources = [...resources].sort((a, b) => b.trend_score - a.trend_score);

// Mock chart data for "Trending Month"
const growthData = [
  { label: 'Week 1', value: 45 },
  { label: 'Week 2', value: 52 },
  { label: 'Week 3', value: 89 },
  { label: 'Week 4', value: 142 },
];

const categoryData = [
  { label: 'LLMs', value: 95 },
  { label: 'Agents', value: 88 },
  { label: 'MLOps', value: 42 },
  { label: 'Math', value: 30 },
];
---

<Layout title="Trending | ReadRadar">
    <Section id="trending-header" title="Trending Analytics" icon="↑">
        <p class="font-mono text-gray-400 max-w-2xl mt-4">
            Real-time insights into the fastest growing technical resources and intelligence vectors.
        </p>
    </Section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-24">
        <div class="neo-card p-8">
            <h3 class="font-heading font-bold text-white mb-6 uppercase text-sm tracking-wider text-gray-400">Resource Growth (30 Days)</h3>
            <BarChart data={growthData} color="bg-[#10B981]" />
        </div>
        <div class="neo-card p-8">
            <h3 class="font-heading font-bold text-white mb-6 uppercase text-sm tracking-wider text-gray-400">Trending Domains</h3>
            <BarChart data={categoryData} color="bg-[#8B5CF6]" />
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-24">
        <Statistics value="+142%" label="MoM Growth" color="text-[#10B981]" />
        <Statistics value="Agentic AI" label="Top Domain" color="text-[#8B5CF6]" />
        <Statistics value="9.9" label="Peak Trend Score" color="text-[#06B6D4]" />
    </div>

    <Section id="trending-table" title="Highest Velocity Resources" icon="⚡">
        <ResourceTable data={trendingResources} client:load />
    </Section>
</Layout>
