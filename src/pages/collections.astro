---
import Layout from '../layouts/Layout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import { Badge } from '../components/ui/Badge';

import collectionsData from '../data/collections.json';
import type { Collection } from '../types';

const collections = collectionsData as Collection[];
---

<Layout title="Curated Collections | ReadRadar">
    <Section id="collections-header" title="Curated Collections" icon="C">
        <p class="font-mono text-gray-300 max-w-2xl mt-4">
            Reading lists and resource collections curated by top AI researchers and engineering organizations.
        </p>
    </Section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {collections.map(collection => (
            <Card href={`${import.meta.env.BASE_URL}/collections/${collection.id}`.replace(/\/\/+/g, '/')} className="group hover:border-secondary flex flex-col h-full focus-within:ring-2 focus-within:ring-secondary focus-within:ring-offset-2 focus-within:ring-offset-background">
                <div class="flex flex-col mb-6">
                    <span class="text-secondary font-mono text-sm mb-2">Curated by {collection.curator}</span>
                    <h3 class="font-heading font-bold text-3xl text-white group-hover:text-secondary transition-colors">{collection.title}</h3>
                </div>
                
                <p class="text-gray-300 text-lg mb-8 flex-grow border-l-4 border-border pl-4">{collection.description}</p>
                
                <div class="mt-auto bg-background p-4 border-2 border-border flex flex-wrap gap-4 justify-between items-center">
                    <div class="flex flex-wrap items-center gap-2 sm:gap-4">
                        <Badge variant="solid">{collection.resources.length} Resources</Badge>
                        <span class="font-mono text-xs text-gray-400">Updated: {new Date(collection.date_updated).toLocaleDateString()}</span>
                    </div>
                    <span class="text-secondary font-bold group-hover:translate-x-1 transition-transform">View Collection →</span>
                </div>
            </Card>
        ))}
    </div>
</Layout>
